[
  "\u0627\u0636\u063a\u0637 \u0639\u0644\u0649 \u0632\u0631 SET- \u0639\u0644\u0649 \u0627\u0644\u062c\u0627\u0646\u0628 \u0627\u0644\u0623\u064a\u0633\u0631 \u0645\u0646 \u0639\u062c\u0644\u0629 \u0627\u0644\u0642\u064a\u0627\u062f\u0629. \u0627\u0636\u0628\u0637 \u0627\u0644\u062d\u062f \u0627\u0644\u0623\u0642\u0635\u0649 \u0644\u0644\u0633\u0631\u0639\u0629 \u0639\u0644\u0649 \u0645\u062b\u0628\u062a \u0627\u0644\u0633\u0631\u0639\u0629",
  "\u05d4\u05de\u05e0\u05e2\u05d5\u05dc \u05d4\u05d7\u05e9\u05de\u05dc\u05d9 \u05e9\u05dc \u05d0\u05e7\u05d3\u05d7 \u05d4\u05d8\u05e2\u05d9\u05e0\u05d4 \u05dc\u05d0 \u05de\u05e9\u05ea\u05d7\u05e8\u05e8, \u05d5\u05e0\u05d9\u05ea\u05df \u05dc\u05e9\u05d7\u05e8\u05e8\u05d5 \u05d9\u05d3\u05e0\u05d9\u05ea \u05d3\u05e8\u05da \u05db\u05d1\u05dc \u05d1\u05ea\u05d0 \u05d4\u05de\u05d8\u05e2\u05df",
  "\u05d0\u05e0\u05d0 \u05e2\u05e6\u05d5\u05e8 \u05d0\u05ea \u05d4\u05e8\u05db\u05d1 \u05dc\u05d7\u05dc\u05d5\u05d8\u05d9\u05df \u05dc\u05e4\u05e0\u05d9 \u05de\u05e2\u05d1\u05e8 \u05dc\u05d4\u05d9\u05dc\u05d5\u05da P",
  "\u0641\u0634\u0644 \u0648\u0636\u0639 P\u060c \u064a\u0631\u062c\u0649 \u0627\u0644\u0641\u062d\u0635 \u0648\u0627\u0644\u0625\u0635\u0644\u0627\u062d",
  "\u05de\u05e2\u05e8\u05db\u05ea \u05e0\u05d4\u05d9\u05d2\u05d4 \u05de\u05e1\u05d9\u05d9\u05e2\u05ea \u05d4\u05ea\u05d7\u05de\u05de\u05d4, \u05ea\u05d7\u05d6\u05d5\u05e8 \u05dc\u05e4\u05e2\u05d5\u05dc\u05d4 \u05dc\u05d0\u05d7\u05e8 \u05e7\u05d9\u05e8\u05d5\u05e8",
  "\u064a\u0631\u062c\u0649 \u0627\u0644\u0636\u063a\u0637 \u0639\u0644\u0649 \u062f\u0648\u0627\u0633\u0629 \u0627\u0644\u0641\u0631\u0627\u0645\u0644 \u0644\u0628\u062f\u0621 \u0627\u0644\u062a\u0634\u063a\u064a\u0644",
  "\u0646\u0638\u0627\u0645 \u0627\u0644\u062a\u062d\u0643\u0645 \u0628\u0627\u0644\u0633\u0631\u0639\u0629 \u0641\u064a \u0627\u0644\u0645\u0633\u0627\u0631 \u064a\u062d\u0627\u0648\u0644 \u0627\u0644\u062a\u0641\u0639\u064a\u0644\u060c \u064a\u0631\u062c\u0649 \u0627\u0644\u0627\u0646\u062a\u0628\u0627\u0647 \u0644\u0644\u062a\u062d\u0643\u0645 \u0628\u0639\u062c\u0644\u0629 \u0627\u0644\u0642\u064a\u0627\u062f\u0629",
  "\u0639\u0637\u0644 \u0641\u064a \u0632\u0631 \u0648\u0636\u0639 P\u060c \u0625\u0630\u0627 \u0643\u0646\u062a \u0628\u062d\u0627\u062c\u0629 \u0625\u0644\u0649 \u0627\u0644\u0631\u0643\u0646\u060c \u064a\u0631\u062c\u0649 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0645\u0641\u062a\u0627\u062d EPB \u0639\u0644\u0649 \u0627\u0644\u0634\u0627\u0634\u0629",
  ",\u0648\u0641\u0642\u064b\u0627 \u0644\u062f\u0631\u062c\u0629 \u0627\u0644\u062d\u0631\u0627\u0631\u0629 \u0627\u0644\u062d\u0627\u0644\u064a\u0629\u060c \u064a\u064f\u0648\u0635\u0649 \u0628\u0636\u0628\u0637 \u0636\u063a\u0637 \u0627\u0644\u0625\u0637\u0627\u0631\u0627\u062a \u0639\u0644\u0649 2.0 bar",
  "\u0e2d\u0e38\u0e13\u0e2b\u0e20\u0e39\u0e21\u0e34\u0e02\u0e2d\u0e07\u0e01\u0e25\u0e49\u0e2d\u0e07\u0e2a\u0e39\u0e07\u0e40\u0e01\u0e34\u0e19\u0e44\u0e1b \u0e23\u0e30\u0e1a\u0e1a\u0e04\u0e27\u0e1a\u0e04\u0e38\u0e21\u0e04\u0e27\u0e32\u0e21\u0e40\u0e23\u0e47\u0e27\u0e2d\u0e31\u0e15\u0e42\u0e19\u0e21\u0e31\u0e15\u0e34\u0e44\u0e21\u0e48\u0e2a\u0e32\u0e21\u0e32\u0e23\u0e16\u0e43\u0e0a\u0e49\u0e07\u0e32\u0e19\u0e44\u0e14\u0e49\u0e0a\u0e31\u0e48\u0e27\u0e04\u0e23\u0e32\u0e27",
  "\u0e01\u0e23\u0e38\u0e13\u0e32\u0e40\u0e0a\u0e37\u0e48\u0e2d\u0e21\u0e15\u0e48\u0e2d \u0e01\u0e38\u0e0d\u0e41\u0e08\u0e1a\u0e25\u0e39\u0e17\u0e18\u0e43\u0e2b\u0e21\u0e48\u0e1c\u0e48\u0e32\u0e19\u0e41\u0e2d\u0e1b\u0e43\u0e19\u0e42\u0e17\u0e23\u0e28\u0e31\u0e1e\u0e17\u0e4c",
  "\u0e01\u0e23\u0e38\u0e13\u0e32\u0e17\u0e4d\u0e32\u0e01\u0e32\u0e23\u0e40\u0e23\u0e35\u0e22\u0e19\u0e23\u0e39\u0e49\u0e14\u0e49\u0e27\u0e22\u0e15\u0e19\u0e40\u0e2d\u0e07\u0e02\u0e2d\u0e07\u0e21\u0e2d\u0e40\u0e15\u0e2d\u0e23\u0e4c",
  "\u0e42\u0e2b\u0e21\u0e14\u0e44\u0e14\u0e19\u0e32\u0e42\u0e21\u0e21\u0e34\u0e40\u0e15\u0e2d\u0e23\u0e4c\u0e40\u0e1b\u0e34\u0e14\u0e43\u0e0a\u0e49\u0e07\u0e32\u0e19\u0e41\u0e25\u0e49\u0e27",
  "\u0e40\u0e1b\u0e34\u0e14\u0e43\u0e0a\u0e49\u0e07\u0e32\u0e19\u0e1f\u0e31\u0e07\u0e01\u0e4c\u0e0a\u0e19\u0e15\u0e34\u0e14\u0e15\u0e32\u0e21\u0e01\u0e25\u0e31\u0e1a\u0e1a\u0e49\u0e32\u0e19",
  "\u0e40\u0e23\u0e37\u0e2d\u0e40\u0e25\u0e47\u0e01\u0e04\u0e27\u0e23\u0e2d\u0e2d\u0e01\u0e08\u0e32\u0e01\u0e1d\u0e31\u0e48\u0e07"
]
